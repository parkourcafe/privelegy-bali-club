# Supabase — deployed public data fails closed without these. Local fixture
# data requires the separate explicit development-only flag below.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional canonical production origin. Production accepts only otherbali.com
# (or www) and otherwise uses https://otherbali.com. Preview derives its origin
# from the trusted Vercel deployment URL; local requests use their own host.
NEXT_PUBLIC_SITE_URL=

# Required for operator queues, invite credential management and private photo
# staging/review. Server-only: never expose this key through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Required whenever VERCEL_ENV=preview and a service key is present. It must be
# the isolated staging project ref; the known production ref is hard-denied.
OTHER_BALI_PREVIEW_SUPABASE_PROJECT_REF=

# Local development fixtures contain explicitly invented demo venues/offers.
# Keep disabled for every deploy. To opt in locally, set exactly YES while
# running `next dev`; production and preview ignore this flag.
OTHER_BALI_ALLOW_FIXTURE_DATA=NO

# 32+ random characters, server-only. Signs venue-bound QR redemption links.
REDEMPTION_SIGNING_SECRET=

# Explicit public TablePilot origin. Production accepts only the production
# origin; preview accepts only a different staging origin and otherwise hides
# TablePilot actions.
NEXT_PUBLIC_TABLEPILOT_URL=

# Optional, server-only. Lets /admin/phase0 pull aggregate BP reservation counts
# from TablePilot. Must match the token configured in the TablePilot project.
TABLEPILOT_PARTNER_TOKEN=
TABLEPILOT_PREVIEW_PARTNER_TOKEN=
TABLEPILOT_PREVIEW_REPORT_URL=
# Optional override. Defaults to the production TablePilot BP report endpoint.
TABLEPILOT_REPORT_URL=

# Required in production to open /admin/* Field Kit pages. Use 32+ random
# characters (not an example/password value). Browser username can be anything;
# password must match this token. Weak or missing values make /admin/* return 404.
ADMIN_ACCESS_TOKEN=
