# Supabase — the app runs on local seed data without these, but redemption
# (the G1 proof) requires a real DB, so set these to record redemptions.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: absolute base URL used when generating counter QR posters.
# If unset, derived from request headers.
NEXT_PUBLIC_SITE_URL=

# Optional, server-only. Lets /admin/phase0 pull aggregate BP reservation counts
# from TablePilot. Must match the token configured in the TablePilot project.
TABLEPILOT_PARTNER_TOKEN=
# Optional override. Defaults to the production TablePilot BP report endpoint.
TABLEPILOT_REPORT_URL=
