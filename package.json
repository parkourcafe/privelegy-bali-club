{
  "name": "privelegy-bali-club",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test lib/*.test.ts lib/actions/*.test.ts lib/actions/__tests__/*.test.ts lib/integrations/*.test.ts lib/privacy/*.test.ts lib/supabase/*.test.ts mobile/tests/*.test.ts scripts/*.test.mjs scripts/*.test.ts",
    "test:watch": "node --import tsx --test --watch lib/*.test.ts lib/actions/*.test.ts lib/actions/__tests__/*.test.ts lib/integrations/*.test.ts lib/privacy/*.test.ts lib/supabase/*.test.ts mobile/tests/*.test.ts scripts/*.test.mjs scripts/*.test.ts",
    "test:e2e": "node scripts/browser-e2e.mjs",
    "test:smoke": "node scripts/smoke-routes.mjs",
    "links:audit": "node scripts/smoke-routes.mjs",
    "data:audit": "tsx scripts/audit-venues.ts",
    "photo:cleanup": "node scripts/reconcile-venue-photo-cleanup.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prebuild": "node scripts/fetch-scenes.mjs || true",
    "mobile:build": "node scripts/build-mobile-shell.mjs",
    "mobile:sync": "cap sync ios",
    "ios:verify": "node scripts/verify-ios-release.mjs",
    "ios:native-readiness": "node scripts/ios-native-readiness.mjs --strict",
    "ios:archive:dry": "npm run mobile:build && npm run mobile:sync && node scripts/verify-ios-release.mjs --archive",
    "mobile:open:ios": "cap open ios",
    "mobile:run:ios": "cap run ios"
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/app-launcher": "8.0.1",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/network": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "4.12.1",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
